# Copy this file to `.env` and fill in a real key. `.env` is gitignored — never commit it.
# The server (poster_tools_server.py) and poster.py load these automatically.

EASYROUTER_API_KEY=sk-REPLACE_WITH_YOUR_KEY
EASYROUTER_BASE_URL=https://easyrouter.io/v1
IMAGE_MODEL=gpt-image-2

# Optional:
# EASYROUTER_TIMEOUT=300
# FROM_BRIEF_ROUTE=images        # images (default, works) | chat (unsupported for gpt-image-2)
